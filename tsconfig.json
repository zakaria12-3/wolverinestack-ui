{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@spartan-ng/helm/sidebar": [
        "./libs/ui/sidebar/src/index.ts"
      ],
      "@spartan-ng/helm/utils": [
        "./libs/ui/utils/src/index.ts"
      ],
      "@spartan-ng/helm/button": [
        "./libs/ui/button/src/index.ts"
      ],
      "@spartan-ng/helm/icon": [
        "./libs/ui/icon/src/index.ts"
      ],
      "@spartan-ng/helm/input": [
        "./libs/ui/input/src/index.ts"
      ],
      "@spartan-ng/helm/separator": [
        "./libs/ui/separator/src/index.ts"
      ],
      "@spartan-ng/helm/sheet": [
        "./libs/ui/sheet/src/index.ts"
      ],
      "@spartan-ng/helm/skeleton": [
        "./libs/ui/skeleton/src/index.ts"
      ],
      "@spartan-ng/helm/tooltip": [
        "./libs/ui/tooltip/src/index.ts"
      ],
      "@spartan-ng/helm/carousel": [
        "./libs/ui/carousel/src/index.ts"
      ],
      "@spartan-ng/helm/card": [
        "./libs/ui/card/src/index.ts"
      ],
      "@spartan-ng/helm/command": [
        "./libs/ui/command/src/index.ts"
      ],
      "@spartan-ng/helm/spinner": [
        "./libs/ui/spinner/src/index.ts"
      ],
      "@spartan-ng/helm/breadcrumb": [
        "./libs/ui/breadcrumb/src/index.ts"
      ],
      "@spartan-ng/helm/avatar": [
        "./libs/ui/avatar/src/index.ts"
      ],
      "@spartan-ng/helm/hover-card": [
        "./libs/ui/hover-card/src/index.ts"
      ],
      "@spartan-ng/helm/badge": [
        "./libs/ui/badge/src/index.ts"
      ],
      "@spartan-ng/helm/typography": [
        "./libs/ui/typography/src/index.ts"
      ],
      "@spartan-ng/helm/calendar": [
        "./libs/ui/calendar/src/index.ts"
      ],
      "@spartan-ng/helm/select": [
        "./libs/ui/select/src/index.ts"
      ],
      "@spartan-ng/helm/alert": [
        "./libs/ui/alert/src/index.ts"
      ]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
